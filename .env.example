# ═══════════════════════════════════════════
# OmniAgent — Environment Configuration
# ═══════════════════════════════════════════
# Copy this file to server/.env and fill in your values.
#
# Quick start with DeepSeek (recommended):
#   1. Get API key at https://platform.deepseek.com
#   2. Fill in DEEPSEEK_API_KEY below
#   3. Run: npm run setup && npm run dev
# ═══════════════════════════════════════════

# ─── LLM Provider ───
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_MODEL_PREF=deepseek-chat

# ─── Embedding (free, runs locally) ───
EMBEDDING_ENGINE=native
EMBEDDING_MODEL_PREF=Xenova/all-MiniLM-L6-v2

# ─── Vector Database (free, zero setup) ───
VECTOR_DB=lancedb

# ─── Security (generate random values) ───
JWT_SECRET=change-me-to-a-random-string-12-chars
SIG_KEY=change-me-to-a-random-string-32-chars
SIG_SALT=change-me-to-a-random-string-32-chars

# ─── Optional: Agent Web Search ───
# Get free key at https://serper.dev (2500 searches/month)
# AGENT_SERPER_DEV_KEY=your-serper-key
