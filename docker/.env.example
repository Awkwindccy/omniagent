# OmniAgent Docker Environment
# Copy this file to docker/.env and fill in your values

# ─── LLM Provider ───
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_MODEL_PREF=deepseek-chat

# ─── Embedding Engine ───
EMBEDDING_ENGINE=native
EMBEDDING_MODEL_PREF=Xenova/all-MiniLM-L6-v2

# ─── Vector Database ───
VECTOR_DB=lancedb

# ─── Security ───
JWT_SECRET=your-random-string-at-least-12-chars
SIG_KEY=your-random-string-at-least-32-chars
SIG_SALT=your-random-string-at-least-32-chars
